rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // User Profiles
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.masteredVerbs is list &&
               data.masteredVerbs.size() <= 2000 &&
               data.updatedAt == request.time;
      }

      // Tiered Identity Logic: Only owner can read/write profile
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isVerified() && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isVerified() && 
                    isValidUserProfile(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['masteredVerbs', 'updatedAt']);
    }

    // Custom Verbs
    match /users/{userId}/customVerbs/{verbId} {
      function isValidCustomVerb(data) {
        return data.verb is string && data.verb.size() <= 100 &&
               data.definition is string && data.definition.size() <= 500 &&
               data.example is string && data.example.size() <= 1000 &&
               data.phonetic is string && data.phonetic.size() <= 100 &&
               data.translation is string && data.translation.size() <= 200 &&
               data.userId == request.auth.uid &&
               (data.keys().hasAll(['createdAt']) ? data.createdAt == request.time : true);
      }

      // Secure List Queries: Explicitly evaluate resource.data
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && isVerified() && 
                    isValidCustomVerb(incoming()) && 
                    incoming().createdAt == request.time;
                    
      allow delete: if isOwner(userId) && isVerified();
    }
  }
}
