{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user mastery and preferences.",
      "type": "object",
      "properties": {
        "masteredWords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of vocabulary items the user has mastered."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the profile was updated."
        }
      },
      "required": ["masteredVerbs", "updatedAt"]
    },
    "customVerb": {
      "title": "Custom Word",
      "description": "Vocabulary items added by the user.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "definition": { "type": "string" },
        "example": { "type": "string" },
        "phonetic": { "type": "string" },
        "translation": { "type": "string" },
        "category": { "type": "string", "enum": ["phrasal", "idiom", "unit0", "unit2", "unit4", "unit6", "unit8", "unit10", "unit12", "unit14", "unit16", "unit18", "unit20", "unit22", "unit24", "unit26"] },
        "userId": { "type": "string", "description": "The owner of this vocabulary item." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["word", "definition", "example", "phonetic", "translation", "category", "userId", "createdAt"]
    },
    "fsrsCard": {
      "title": "FSRS Card",
      "description": "FSRS memory state for a specific word.",
      "type": "object",
      "properties": {
        "wordId": { "type": "string", "description": "The word identifier (usually the word itself or custom word ID)" },
        "category": { "type": "string" },
        "deck": { "type": "string", "description": "The custom deck name." },
        "due": { "type": "string", "format": "date-time" },
        "stability": { "type": "number" },
        "difficulty": { "type": "number" },
        "elapsed_days": { "type": "number" },
        "scheduled_days": { "type": "number" },
        "reps": { "type": "number" },
        "lapses": { "type": "number" },
        "state": { "type": "number", "description": "New=0, Learning=1, Review=2, Relearning=3" },
        "last_review": { "type": "string", "format": "date-time" }
      },
      "required": ["wordId", "category", "due", "stability", "difficulty", "elapsed_days", "scheduled_days", "reps", "lapses", "state"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User preferences and mastery state."
    },
    "/users/{userId}/customVerbs/{wordId}": {
      "schema": "customVerb",
      "description": "Custom vocabulary items added by the specific user."
    },
    "/users/{userId}/fsrsCards/{wordId}": {
      "schema": "fsrsCard",
      "description": "Progress tracking for words in MemoFlow."
    }
  }
}
