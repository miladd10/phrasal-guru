{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user mastery and preferences.",
      "type": "object",
      "properties": {
        "masteredWords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of vocabulary items the user has mastered."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the profile was updated."
        }
      },
      "required": ["masteredVerbs", "updatedAt"]
    },
    "customVerb": {
      "title": "Custom Word",
      "description": "Vocabulary items added by the user.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "definition": { "type": "string" },
        "example": { "type": "string" },
        "phonetic": { "type": "string" },
        "translation": { "type": "string" },
        "category": { "type": "string", "enum": ["phrasal", "idiom", "unit2", "unit4", "unit6", "unit8", "unit10", "unit12", "unit14", "unit16", "unit18", "unit20", "unit22", "unit24", "unit26"] },
        "userId": { "type": "string", "description": "The owner of this vocabulary item." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["word", "definition", "example", "phonetic", "translation", "category", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User preferences and mastery state."
    },
    "/users/{userId}/customVerbs/{wordId}": {
      "schema": "customVerb",
      "description": "Custom vocabulary items added by the specific user."
    }
  }
}
